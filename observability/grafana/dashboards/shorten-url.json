{
  "uid": "shorten-url",
  "title": "ShortenUrl — Redirects & Analytics",
  "tags": ["shortenurl", "url-shortener", "redirects"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 2,
  "time": { "from": "now-6h", "to": "now" },
  "refresh": "30s",
  "panels": [
    {
      "id": 1, "type": "stat", "title": "Service Up",
      "gridPos": { "h": 3, "w": 3, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "DOWN", "color": "red" }, "1": { "text": "UP", "color": "green" } } }
          ]
        }
      },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "up{instance=~\"shorten-api.*\"}" }
      ]
    },
    {
      "id": 2, "type": "stat", "title": "URLs Created",
      "gridPos": { "h": 3, "w": 3, "x": 3, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "short" } },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "url_created_total" }
      ]
    },
    {
      "id": 3, "type": "stat", "title": "Total Redirects",
      "gridPos": { "h": 3, "w": 3, "x": 6, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "blue", "value": 0 }] }, "unit": "short" } },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(url_redirects_total)" }
      ]
    },
    {
      "id": 4, "type": "stat", "title": "Redirects Today",
      "gridPos": { "h": 3, "w": 3, "x": 9, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "green", "value": 0 }] }, "unit": "short" } },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "increase(sum(url_redirects_total)[24h])" }
      ]
    },
    {
      "id": 5, "type": "stat", "title": "Redirects/min",
      "gridPos": { "h": 3, "w": 3, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "reqpm" } },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rate(url_redirects_total[1m])) * 60" }
      ]
    },
    {
      "id": 6, "type": "stat", "title": "Unique Visitors",
      "gridPos": { "h": 3, "w": 3, "x": 15, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "short" } },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(unique_visitors_total)" }
      ]
    },
    {
      "id": 7, "type": "stat", "title": "Unique Countries",
      "gridPos": { "h": 3, "w": 3, "x": 18, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": {} },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "count(count by (country) (url_redirects_by_country_total))" }
      ]
    },
    {
      "id": 8, "type": "stat", "title": "Unique IPs (/24)",
      "gridPos": { "h": 3, "w": 3, "x": 21, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": {} },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "count(count by (ip_prefix) (url_redirects_by_ip_total))" }
      ]
    },
    {
      "id": 20, "type": "timeseries", "title": "Redirects/sec by URL",
      "gridPos": { "h": 10, "w": 12, "x": 0, "y": 3 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "reqps" }, "overrides": [] },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by (short_code) (rate(url_redirects_total[1m]))", "legendFormat": "/{{short_code}}" }
      ]
    },
    {
      "id": 21, "type": "timeseries", "title": "Total Redirects by URL (cumulative)",
      "gridPos": { "h": 10, "w": 12, "x": 12, "y": 3 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by (short_code) (url_redirects_total)", "legendFormat": "/{{short_code}}" }
      ]
    },
    {
      "id": 22, "type": "timeseries", "title": "Redirects by Country",
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 13 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "reqps" }, "overrides": [] },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by (country) (rate(url_redirects_by_country_total[1m]))", "legendFormat": "{{country}}" }
      ]
    },
    {
      "id": 23, "type": "timeseries", "title": "API p95 Latency (edge)",
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 13 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.95, sum by (le) (rate(traefik_service_request_duration_seconds_bucket{service=~\"api@.*\"}[5m])))", "legendFormat": "p95" }
      ]
    },
    {
      "id": 24, "type": "timeseries", "title": "HTTP Status Breakdown",
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 22 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "reqps" }, "overrides": [] },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by (code) (rate(traefik_service_requests_total{service=~\"api@.*\"}[1m]))", "legendFormat": "{{code}}" }
      ]
    },
    {
      "id": 25, "type": "timeseries", "title": "Unique Visitors by URL",
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 22 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by (short_code) (unique_visitors_total)", "legendFormat": "/{{short_code}}" }
      ]
    },
    {
      "id": 30, "type": "timeseries", "title": "Resident Memory (RSS)",
      "gridPos": { "h": 6, "w": 12, "x": 0, "y": 29 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "bytes" }, "overrides": [] },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "process_resident_memory_bytes{instance=~\"shorten-api.*\"}", "legendFormat": "rss" }
      ]
    },
    {
      "id": 31, "type": "timeseries", "title": "Event-loop Lag",
      "gridPos": { "h": 6, "w": 12, "x": 12, "y": 29 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "nodejs_eventloop_lag_seconds{instance=~\"shorten-api.*\"}", "legendFormat": "lag" }
      ]
    }
  ]
}
